# Your Neon PostgreSQL connection string (Format: postgresql://[user]:[password]@[host]/[dbname]?sslmode=require)
DATABASE_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"

# API Key for Google Search using Serper.dev
SERPER_API_KEY="your_serper_api_key_here"

# API Key for Google Gemini (For future use in Phase 2)
GEMINI_API_KEY="your_gemini_api_key_here"
